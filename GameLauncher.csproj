<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ApplicationIcon>game.ico</ApplicationIcon>
    <Version>2.0.1</Version>
    <AssemblyVersion>2.0.1.0</AssemblyVersion>
    <FileVersion>2.0.1.0</FileVersion>
    <SatelliteResourceLanguages>en</SatelliteResourceLanguages>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>



  <ItemGroup>
    <PackageReference Include="LibreHardwareMonitorLib" Version="0.9.7-pre656" />
  </ItemGroup>

  <ItemGroup>
    <Resource Include="game.ico" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="GameLauncher.Tests\**\*.cs" />
    <EmbeddedResource Remove="GameLauncher.Tests\**\*" />
    <None Remove="GameLauncher.Tests\**\*" />
    <Page Remove="GameLauncher.Tests\**\*" />
  </ItemGroup>

</Project>
