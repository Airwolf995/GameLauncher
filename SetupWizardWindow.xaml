<Window x:Class="GameLauncher.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:GameLauncher.Services.Localization"
        Title="{loc:Loc Key=Wizard.Title}" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#1E1E1E" Foreground="White"
        WindowStyle="None" AllowsTransparency="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Modern Button Style -->
        <!-- Modern Button Style (Inherits Global) -->
        <Style x:Key="ModernButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="24,12"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#333333"/>
            <!-- Note: Template triggers in global style use TemplateBinding Background, so changing Background here works -->
        </Style>

        <Style x:Key="LanguageButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#252526" Offset="0"/>
                <GradientStop Color="#1E1E1E" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Background="#2D2D30" CornerRadius="12,0,0,12">
                <StackPanel Margin="24,48,24,24">
                    <Image Source="game.ico" Width="80" Height="80" Margin="0,0,0,32">
                        <Image.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                        </Image.Effect>
                    </Image>
                    <TextBlock Text="{loc:Loc Key=Wizard.SidebarTitle}" FontSize="22" FontWeight="Bold" Margin="0,0,0,40" HorizontalAlignment="Center"/>
                    
                    <StackPanel x:Name="IndicatorPanel">
                        <TextBlock x:Name="Step1Indicator" Text="{loc:Loc Key=Wizard.Step1}" Foreground="#007ACC" Margin="0,8" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock x:Name="Step2Indicator" Text="{loc:Loc Key=Wizard.Step2}" Foreground="#888888" Margin="0,8" FontSize="15"/>
                        <TextBlock x:Name="Step3Indicator" Text="{loc:Loc Key=Wizard.Step3}" Foreground="#888888" Margin="0,8" FontSize="15"/>
                        <TextBlock x:Name="Step4Indicator" Text="{loc:Loc Key=Wizard.Step4}" Foreground="#888888" Margin="0,8" FontSize="15"/>
                        <TextBlock x:Name="Step5Indicator" Text="{loc:Loc Key=Wizard.Step5}" Foreground="#888888" Margin="0,8" FontSize="15"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1" Margin="40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Steps -->
                <Grid x:Name="StepsContainer">
                    
                    <!-- Step 1: Welcome -->
                    <StackPanel x:Name="Step1" Visibility="Visible">
                        <TextBlock Text="{loc:Loc Key=Wizard.WelcomeHeadline}" FontSize="32" FontWeight="Bold" Margin="0,0,0,24"/>
                        <TextBlock Text="{loc:Loc Key=Wizard.WelcomeBody}" 
                                 FontSize="16" TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,0,0,24" LineHeight="24"/>
                        <TextBlock Text="{loc:Loc Key=Wizard.WelcomeTime}" 
                                 FontSize="14" Foreground="#888888" Margin="0,0,0,16"/>
                        <TextBlock Text="{loc:Loc Key=Wizard.LanguagePrompt}" FontSize="13" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="EnglishLanguageButton"
                                    Content="{loc:Loc Key=Language.English}"
                                    Style="{StaticResource LanguageButton}"
                                    Click="EnglishLanguageButton_Click"/>
                            <Button x:Name="GermanLanguageButton"
                                    Content="{loc:Loc Key=Language.German}"
                                    Style="{StaticResource LanguageButton}"
                                    Click="GermanLanguageButton_Click"/>
                        </StackPanel>
                        <TextBlock Text="{loc:Loc Key=Wizard.LanguageHelp}" FontSize="12" Foreground="#888888" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Step 2: Spiele -->
                    <StackPanel x:Name="Step2" Visibility="Collapsed">
                        <TextBlock Text="{loc:Loc Key=Wizard.GamesHeadline}" FontSize="32" FontWeight="Bold" Margin="0,0,0,12"/>
                        <TextBlock Text="{loc:Loc Key=Wizard.GamesBody}"
                                 FontSize="15" TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,0,0,16" LineHeight="22"/>

                        <Border Background="#2D2D30" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc Key=Wizard.GamesPlatformsTitle}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                <TextBlock Text="{loc:Loc Key=Wizard.GamesPlatformsBody}" FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{loc:Loc Key=Wizard.GamesFooter}"
                                 FontSize="12" Foreground="#888888" Margin="0,10,0,0" FontStyle="Italic" TextWrapping="Wrap"/>
                    </StackPanel>

                    <ScrollViewer x:Name="Step3" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" Padding="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="{loc:Loc Key=Wizard.LibrariesHeadline}" FontSize="32" FontWeight="Bold" Margin="0,0,0,12"/>

                            <TextBlock x:Name="LibraryDetectionStatusText" Text="{loc:Loc Key=Wizard.LibrariesIdle}" Foreground="#888888" FontSize="12" Margin="0,0,0,12"/>

                            <StackPanel x:Name="LibraryPathInputsPanel" Visibility="Collapsed">
                                <TextBlock Text="{loc:Loc Key=Wizard.LibrariesBody}"
                                         FontSize="15" TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,0,0,16" LineHeight="22"/>

                                <TextBlock Text="{loc:Loc Key=Wizard.SteamPaths}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="WizardSteamPathsBox" Height="54" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                                <TextBlock Text="{loc:Loc Key=Wizard.EpicPaths}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="WizardEpicPathsBox" Height="54" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                                <TextBlock Text="{loc:Loc Key=Wizard.XboxPaths}" FontSize="13" Margin="0,0,0,5"/>
                                <TextBox x:Name="WizardXboxPathsBox" Height="54" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10"/>

                                <TextBlock Text="{loc:Loc Key=Wizard.PathHelp}"
                                         FontSize="12" Foreground="#888888" TextWrapping="Wrap" LineHeight="18" Margin="0,0,0,8"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Step 4: Appearance -->
                    <StackPanel x:Name="Step4" Visibility="Collapsed">
                        <TextBlock Text="{loc:Loc Key=Wizard.AppearanceHeadline}" FontSize="32" FontWeight="Bold" Margin="0,0,0,24"/>
                        <TextBlock Text="{loc:Loc Key=Wizard.AppearanceBody}" 
                                 FontSize="16" TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,0,0,24"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                            <TextBlock Text="{loc:Loc Key=Wizard.Theme}" VerticalAlignment="Center" Width="100" FontSize="15"/>
                            <ComboBox x:Name="ThemeBox" Width="220" Padding="8" SelectionChanged="ThemeBox_SelectionChanged">
                                <ComboBoxItem Content="{loc:Loc Key=Theme.Blue}" Tag="Blue" IsSelected="True"/>
                                <ComboBoxItem Content="{loc:Loc Key=Theme.Red}" Tag="Red"/>
                                <ComboBoxItem Content="{loc:Loc Key=Theme.Green}" Tag="Green"/>
                                <ComboBoxItem Content="{loc:Loc Key=Theme.Orange}" Tag="Orange"/>
                                <ComboBoxItem Content="{loc:Loc Key=Theme.Purple}" Tag="Purple"/>
                                <ComboBoxItem Content="{loc:Loc Key=Theme.Pink}" Tag="Pink"/>
                                <ComboBoxItem Content="{loc:Loc Key=Theme.Dark}" Tag="Dark"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{loc:Loc Key=Wizard.CardSize}" VerticalAlignment="Center" Width="100" FontSize="15"/>
                            <ComboBox x:Name="CardSizeBox" Width="220" Padding="8">
                                <ComboBoxItem Content="{loc:Loc Key=CardSize.Small}" Tag="Small"/>
                                <ComboBoxItem Content="{loc:Loc Key=CardSize.Medium}" Tag="Medium" IsSelected="True"/>
                                <ComboBoxItem Content="{loc:Loc Key=CardSize.Large}" Tag="Large"/>
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>

                    <!-- Step 5: Finish -->
                    <StackPanel x:Name="Step5" Visibility="Collapsed">
                        <TextBlock Text="{loc:Loc Key=Wizard.FinishHeadline}" FontSize="32" FontWeight="Bold" Margin="0,0,0,24"/>
                        <TextBlock Text="{loc:Loc Key=Wizard.FinishBody}" 
                                 FontSize="16" TextWrapping="Wrap" Foreground="#CCCCCC" Margin="0,0,0,24" LineHeight="24"/>
                        
                        <TextBlock Text="{loc:Loc Key=Wizard.FinishEnjoy}" 
                                 FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AccentColor}" HorizontalAlignment="Center" Margin="0,48,0,0"/>
                    </StackPanel>

                </Grid>

                <!-- Navigation Buttons -->
                <Grid Grid.Row="1" Margin="0,24,0,0">
                    <Button x:Name="BtnBack" Content="{loc:Loc Key=Common.Back}" HorizontalAlignment="Left" Style="{StaticResource SecondaryButton}" Click="BtnBack_Click" Visibility="Hidden"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnNext" Content="{loc:Loc Key=Common.Next}" Style="{StaticResource ModernButton}" Click="BtnNext_Click"/>
                        <Button x:Name="BtnFinish" Content="{loc:Loc Key=Common.Finish}" Style="{StaticResource ModernButton}" Click="BtnFinish_Click" Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Grid>
    </Border>
</Window>
